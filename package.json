{
  "name": "quickwit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"tsx watch server/index.ts\" \"vite\"",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node server-dist/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "4.3.4",
    "express": "4.22.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "socket.io": "4.8.1",
    "socket.io-client": "4.8.1",
    "vite": "6.4.3"
  },
  "devDependencies": {
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "concurrently": "9.1.2",
    "tsx": "4.23.1",
    "typescript": "5.7.2",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">=20.10"
  }
}
